common --announce_rc

test --test_output=errors
common --show_result=100
common --java_runtime_version=remotejdk_21 --java_language_version=11
common --tool_java_runtime_version=remotejdk_21 --tool_java_language_version=11
common --extra_toolchains=@//:all
common --@protobuf//bazel/toolchains:prefer_prebuilt_protoc
common --incompatible_enable_proto_toolchain_resolution
common --cxxopt=-std=c++17 --host_cxxopt=-std=c++17

build:bb --bes_results_url=https://app.buildbuddy.io/invocation/
build:bb --bes_backend=grpcs://remote.buildbuddy.io
build:bb --remote_cache=grpcs://remote.buildbuddy.io
build:bb --remote_timeout=3600
build:bb --remote_executor=grpcs://remote.buildbuddy.io
build:bb --host_platform=@toolchains_buildbuddy//platforms:linux_x86_64
build:bb --platforms=@toolchains_buildbuddy//platforms:linux_x86_64
build:bb --extra_execution_platforms=@toolchains_buildbuddy//platforms:linux_x86_64
build:bb --crosstool_top=@toolchains_buildbuddy//platforms:linux_x86_64
build:bb --remote_cache_compression
build:bb --jobs=50
build:bb --noslim_profile --experimental_profile_include_target_label --experimental_profile_include_primary_output